{
  "name": "@71z/hemcss",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.1.0",
  "description": "HẻmCSS — a semantic-class CSS component library with OKLCH tokens, cascade layers, and zero Tailwind dependency.",
  "keywords": [
    "css",
    "components",
    "postcss",
    "design-system",
    "oklch",
    "cascade-layers"
  ],
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "src",
    "plugin",
    "vite-plugin",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": "./dist/hemcss.css",
    "./min": "./dist/hemcss.min.css",
    "./no-reset": "./dist/hemcss.no-reset.css",
    "./no-reset/min": "./dist/hemcss.no-reset.min.css",
    "./themes/hanoi-light": "./dist/themes/hanoi-light.css",
    "./themes/hanoi-light/min": "./dist/themes/hanoi-light.min.css",
    "./themes/hanoi-dark": "./dist/themes/hanoi-dark.css",
    "./themes/hanoi-dark/min": "./dist/themes/hanoi-dark.min.css",
    "./themes/saigon-light": "./dist/themes/saigon-light.css",
    "./themes/saigon-light/min": "./dist/themes/saigon-light.min.css",
    "./themes/saigon-dark": "./dist/themes/saigon-dark.css",
    "./themes/saigon-dark/min": "./dist/themes/saigon-dark.min.css",
    "./base": "./dist/hemcss.base.css",
    "./base/min": "./dist/hemcss.base.min.css",
    "./components/btn": "./dist/components/btn.css",
    "./components/btn/min": "./dist/components/btn.min.css",
    "./components/card": "./dist/components/card.css",
    "./components/card/min": "./dist/components/card.min.css",
    "./components/input": "./dist/components/input.css",
    "./components/input/min": "./dist/components/input.min.css",
    "./components/textarea": "./dist/components/textarea.css",
    "./components/textarea/min": "./dist/components/textarea.min.css",
    "./components/select": "./dist/components/select.css",
    "./components/select/min": "./dist/components/select.min.css",
    "./components/checkbox": "./dist/components/checkbox.css",
    "./components/checkbox/min": "./dist/components/checkbox.min.css",
    "./components/radio": "./dist/components/radio.css",
    "./components/radio/min": "./dist/components/radio.min.css",
    "./components/toggle": "./dist/components/toggle.css",
    "./components/toggle/min": "./dist/components/toggle.min.css",
    "./components/label": "./dist/components/label.css",
    "./components/label/min": "./dist/components/label.min.css",
    "./components/badge": "./dist/components/badge.css",
    "./components/badge/min": "./dist/components/badge.min.css",
    "./components/alert": "./dist/components/alert.css",
    "./components/alert/min": "./dist/components/alert.min.css",
    "./components/avatar": "./dist/components/avatar.css",
    "./components/avatar/min": "./dist/components/avatar.min.css",
    "./components/divider": "./dist/components/divider.css",
    "./components/divider/min": "./dist/components/divider.min.css",
    "./components/loading": "./dist/components/loading.css",
    "./components/loading/min": "./dist/components/loading.min.css",
    "./components/kbd": "./dist/components/kbd.css",
    "./components/kbd/min": "./dist/components/kbd.min.css",
    "./components/navbar": "./dist/components/navbar.css",
    "./components/navbar/min": "./dist/components/navbar.min.css",
    "./components/menu": "./dist/components/menu.css",
    "./components/menu/min": "./dist/components/menu.min.css",
    "./components/breadcrumb": "./dist/components/breadcrumb.css",
    "./components/breadcrumb/min": "./dist/components/breadcrumb.min.css",
    "./components/tabs": "./dist/components/tabs.css",
    "./components/tabs/min": "./dist/components/tabs.min.css",
    "./components/steps": "./dist/components/steps.css",
    "./components/steps/min": "./dist/components/steps.min.css",
    "./components/pagination": "./dist/components/pagination.css",
    "./components/pagination/min": "./dist/components/pagination.min.css",
    "./components/stack": "./dist/components/stack.css",
    "./components/stack/min": "./dist/components/stack.min.css",
    "./components/grid": "./dist/components/grid.css",
    "./components/grid/min": "./dist/components/grid.min.css",
    "./components/modal": "./dist/components/modal.css",
    "./components/modal/min": "./dist/components/modal.min.css",
    "./components/sheet": "./dist/components/sheet.css",
    "./components/sheet/min": "./dist/components/sheet.min.css",
    "./components/dropdown": "./dist/components/dropdown.css",
    "./components/dropdown/min": "./dist/components/dropdown.min.css",
    "./components/collapse": "./dist/components/collapse.css",
    "./components/collapse/min": "./dist/components/collapse.min.css",
    "./components/tooltip": "./dist/components/tooltip.css",
    "./components/tooltip/min": "./dist/components/tooltip.min.css",
    "./components/toast": "./dist/components/toast.css",
    "./components/toast/min": "./dist/components/toast.min.css",
    "./components/table": "./dist/components/table.css",
    "./components/table/min": "./dist/components/table.min.css",
    "./components/stat": "./dist/components/stat.css",
    "./components/stat/min": "./dist/components/stat.min.css",
    "./components/countdown": "./dist/components/countdown.css",
    "./components/countdown/min": "./dist/components/countdown.min.css",
    "./polyfill/grid": "./polyfill/grid.js",
    "./tokens/schema": "./dist/tokens/schema.json",
    "./plugin": "./plugin/index.js",
    "./vite": "./vite-plugin/index.js",
    "./src/*": "./src/*"
  },
  "scripts": {
    "build": "pnpm build:schema && pnpm build:core && pnpm build:core:min && pnpm build:no-reset && pnpm build:no-reset:min && pnpm build:base && pnpm build:base:min && pnpm build:components && pnpm build:themes",
    "build:core": "postcss src/index.css -o dist/hemcss.css",
    "build:core:min": "postcss src/index.css -o dist/hemcss.min.css --env min",
    "build:no-reset": "cross-env HEMCSS_NO_RESET=1 postcss src/index.css -o dist/hemcss.no-reset.css",
    "build:no-reset:min": "cross-env HEMCSS_NO_RESET=1 postcss src/index.css -o dist/hemcss.no-reset.min.css --env min",
    "build:themes": "node scripts/build-themes.js",
    "build:base": "postcss src/base.css -o dist/hemcss.base.css",
    "build:base:min": "postcss src/base.css -o dist/hemcss.base.min.css --env min",
    "build:components": "node scripts/build-components.js",
    "build:schema": "node scripts/build-schema.js",
    "dev": "postcss src/index.css -o dist/hemcss.css --watch",
    "lint": "stylelint 'src/**/*.css'",
    "lint:fix": "stylelint 'src/**/*.css' --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "cross-env": "^10",
    "cssnano": "^7",
    "postcss": "^8",
    "postcss-cli": "^11",
    "postcss-import": "^16",
    "postcss-nesting": "^14",
    "stylelint": "^17",
    "stylelint-config-standard": "^40",
    "vitest": "^4"
  }
}
